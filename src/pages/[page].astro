---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArchivePage from '../components/ArchivePage.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getPublishedPosts, buildArchivePage, PAGE_SIZE } from '../utils';

export async function getStaticPaths() {
  const all = await getPublishedPosts();
  const lastPage = Math.max(1, Math.ceil(all.length / PAGE_SIZE));
  const paths = [];
  for (let n = 2; n <= lastPage; n++) {
    paths.push({
      params: { page: String(n) },
      props: { page: buildArchivePage(all, n) },
    });
  }
  return paths;
}

const { page } = Astro.props;
---

<BaseLayout title={`${SITE_TITLE} · 第 ${page.currentPage} 页`} description={SITE_DESCRIPTION}>
  <ArchivePage page={page} />
</BaseLayout>
