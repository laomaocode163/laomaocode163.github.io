---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION, AUTHOR, SOCIAL_LINKS } from '../consts';
import { getPublishedPosts, getTagCounts } from '../utils';

const posts = await getPublishedPosts();
const tagCounts = getTagCounts(posts);
const postCount = posts.length;
const tagCount = tagCounts.length;
const sinceYear = posts.length
  ? Math.min(...posts.map((p) => p.data.pubDate.getFullYear()))
  : new Date().getFullYear();
// 取出现频率最高的标签作为「常写方向」
const topTags = tagCounts.slice(0, 8);

const features = [
  { label: 'Markdown 写作', desc: '纯文本，零负担记录' },
  { label: '代码高亮', desc: 'Shiki 亮/暗双主题' },
  { label: '标签分类', desc: '按主题快速检索' },
  { label: '暗色模式', desc: '护眼的夜间阅读' },
  { label: '站内搜索', desc: 'Pagefind 全文检索' },
  { label: 'RSS 订阅', desc: '及时获取更新' },
];
---

<BaseLayout title={`关于 · ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <!-- 个人卡片 -->
  <section class="mx-auto max-w-5xl px-4 pt-12 sm:px-6">
    <div
      class="animate-fade-up rounded-3xl border border-brand-100 bg-gradient-to-br from-brand-50 to-white p-8 shadow-sm dark:border-brand-900/40 dark:from-brand-900/20 dark:to-slate-950 sm:p-12"
    >
      <div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center">
        <img
          src={AUTHOR.avatar}
          alt={AUTHOR.name}
          width="96"
          height="96"
          class="h-20 w-20 shrink-0 rounded-2xl bg-white object-cover shadow-md ring-4 ring-white/70 dark:ring-slate-900/40 sm:h-24 sm:w-24"
        />
        <div class="min-w-0">
          <h1
            class="bg-gradient-to-r from-brand-600 to-indigo-500 bg-clip-text text-3xl font-bold tracking-tight text-transparent sm:text-4xl dark:from-brand-300 dark:to-indigo-300"
          >
            你好，我是 {AUTHOR.name} 👋
          </h1>
          <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600 dark:text-slate-400">
            {AUTHOR.bio}
          </p>
          <div class="mt-5 flex flex-wrap gap-3">
            {
              SOCIAL_LINKS.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white/60 px-4 py-2 text-sm font-medium text-slate-600 transition hover:-translate-y-0.5 hover:border-brand-300 hover:text-brand-700 dark:border-slate-700 dark:bg-slate-900/40 dark:text-slate-300 dark:hover:border-brand-700 dark:hover:text-brand-300"
                >
                  {link.label === 'GitHub' && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="h-4 w-4"
                    >
                      <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                      <path d="M9 18c-4.51 2-5-2-7-2" />
                    </svg>
                  )}
                  {link.label === 'Twitter' && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="h-4 w-4"
                    >
                      <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z" />
                    </svg>
                  )}
                  {link.label === 'Email' && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="h-4 w-4"
                    >
                      <rect width="20" height="16" x="2" y="4" rx="2" />
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                  )}
                  {link.label}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 数据统计 -->
  <section class="mx-auto grid max-w-5xl grid-cols-3 gap-4 px-4 pt-6 sm:px-6">
    <div
      class="animate-fade-up rounded-2xl border border-slate-200 bg-white p-5 text-center shadow-sm dark:border-slate-800 dark:bg-slate-900"
    >
      <div class="text-3xl font-bold text-brand-600 dark:text-brand-300">{postCount}</div>
      <div class="mt-1 text-sm text-slate-500 dark:text-slate-400">篇文章</div>
    </div>
    <div
      class="animate-fade-up rounded-2xl border border-slate-200 bg-white p-5 text-center shadow-sm dark:border-slate-800 dark:bg-slate-900"
    >
      <div class="text-3xl font-bold text-brand-600 dark:text-brand-300">{tagCount}</div>
      <div class="mt-1 text-sm text-slate-500 dark:text-slate-400">个标签</div>
    </div>
    <div
      class="animate-fade-up rounded-2xl border border-slate-200 bg-white p-5 text-center shadow-sm dark:border-slate-800 dark:bg-slate-900"
    >
      <div class="text-3xl font-bold text-brand-600 dark:text-brand-300">{sinceYear}</div>
      <div class="mt-1 text-sm text-slate-500 dark:text-slate-400">年起笔耕</div>
    </div>
  </section>

  <!-- 关于 -->
  <section class="mx-auto grid max-w-5xl gap-6 px-4 pb-20 pt-10 sm:px-6 lg:grid-cols-5">
    <!-- 关于我 -->
    <div
      class="animate-fade-up rounded-3xl border border-slate-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-slate-900 lg:col-span-3"
    >
      <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100">关于我</h2>
      <p class="mt-4 text-base leading-8 text-slate-600 dark:text-slate-400">
        欢迎来到我的个人博客。这里主要记录我在前端工程化、DevOps
        以及各类效率工具上的学习笔记与实践心得，也会分享一些生活里的思考与碎碎念。我会持续把日常踩坑、技能沉淀和有趣的想法整理成文，希望对你也有所启发。
      </p>

      {
        topTags.length > 0 && (
          <>
            <h3 class="mt-8 text-sm font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500">
              常写方向
            </h3>
            <div class="mt-3 flex flex-wrap gap-2">
              {topTags.map((t) => (
                <a
                  href={`/tags/${encodeURIComponent(t.tag)}`}
                  class="inline-flex items-center gap-1.5 rounded-full border border-brand-200 bg-brand-50 px-3 py-1.5 text-sm text-brand-700 transition hover:bg-brand-100 dark:border-brand-800/60 dark:bg-brand-900/30 dark:text-brand-300 dark:hover:bg-brand-900/60"
                >
                  #{t.tag}
                  <span class="rounded-full bg-white/70 px-1.5 text-xs text-brand-600 dark:bg-slate-900/50 dark:text-brand-400">
                    {t.count}
                  </span>
                </a>
              ))}
            </div>
          </>
        )
      }
    </div>

    <!-- 关于这个博客 -->
    <div
      class="animate-fade-up rounded-3xl border border-brand-100 bg-gradient-to-br from-brand-50 to-white p-8 shadow-sm dark:border-brand-900/40 dark:from-brand-900/20 dark:to-slate-950 lg:col-span-2"
    >
      <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100">关于这个博客</h2>
      <p class="mt-4 text-base leading-8 text-slate-600 dark:text-slate-400">
        这是一个基于 Astro + Tailwind CSS 构建的静态个人博客，零运行时
        JavaScript，加载飞快。下面这些小特性让阅读更舒服：
      </p>
      <ul class="mt-6 space-y-3">
        {
          features.map((f) => (
            <li class="flex items-start gap-3">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="mt-0.5 h-5 w-5 shrink-0 text-brand-500"
              >
                <path d="M20 6 9 17l-5-5" />
              </svg>
              <div>
                <div class="text-sm font-medium text-slate-800 dark:text-slate-200">{f.label}</div>
                <div class="text-xs text-slate-500 dark:text-slate-400">{f.desc}</div>
              </div>
            </li>
          ))
        }
      </ul>
      <p class="mt-6 text-sm text-slate-500 dark:text-slate-400">
        如果文章对你有帮助，或想交流任何问题，欢迎通过左侧社交账号联系我。
      </p>
    </div>
  </section>
</BaseLayout>
