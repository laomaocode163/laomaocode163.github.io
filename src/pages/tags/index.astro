---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagPill from '../../components/TagPill.astro';
import { getPublishedPosts, getTagCounts } from '../../utils';

const posts = await getPublishedPosts();
const tagCounts = getTagCounts(posts);
---

<BaseLayout title="标签" description="按标签浏览全部技术文章">
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6">
    <header class="mb-10">
      <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100">标签</h1>
      <p class="mt-2 text-slate-500 dark:text-slate-400">
        共 {tagCounts.length} 个标签，点击进入对应文章列表。
      </p>
    </header>

    {
      tagCounts.length === 0 ? (
        <p class="text-slate-500">暂无标签。</p>
      ) : (
        <div class="flex flex-wrap gap-3">
          {tagCounts.map(({ tag, count }) => (
            <TagPill tag={tag} count={count} size="md" />
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
