---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts } from '../../utils';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) tags.add(tag);
  }
  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter((p) => p.data.tags.includes(tag)),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`标签：${tag}`} description={`标签「${tag}」下的全部文章`}>
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6">
    <nav class="mb-6 text-sm text-slate-400 dark:text-slate-500">
      <a href="/tags" class="transition hover:text-brand-600 dark:hover:text-brand-400">标签</a>
      <span class="mx-2">/</span>
      <span class="text-slate-600 dark:text-slate-300">#{tag}</span>
    </nav>

    <header class="mb-10">
      <h1 class="flex items-center gap-2 text-3xl font-bold text-slate-900 dark:text-slate-100">
        <span class="text-brand-500">#</span>{tag}
      </h1>
      <p class="mt-2 text-slate-500 dark:text-slate-400">共 {posts.length} 篇文章</p>
    </header>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </div>
</BaseLayout>
