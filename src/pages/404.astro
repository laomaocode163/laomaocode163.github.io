---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到">
  <div class="mx-auto max-w-3xl px-4 py-24 text-center sm:px-6">
    <p class="text-6xl font-bold text-brand-500">404</p>
    <h1 class="mt-4 text-2xl font-bold text-slate-900 dark:text-slate-100">页面未找到</h1>
    <p class="mt-2 text-slate-500 dark:text-slate-400">
      你访问的页面不存在，或已被移动。
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center rounded-full bg-brand-600 px-6 py-3 text-sm font-medium text-white transition hover:bg-brand-700"
    >
      返回首页
    </a>
  </div>
</BaseLayout>
