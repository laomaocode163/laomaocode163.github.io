---
import { SOCIAL_LINKS, SITE_TITLE } from '../consts';
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-950">
  <div
    class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-4 py-8 sm:px-6 md:flex-row"
  >
    <p class="text-sm text-slate-500 dark:text-slate-400">
      © {year} {SITE_TITLE}. 由
      <a
        href="https://astro.build"
        class="font-medium text-brand-600 hover:underline dark:text-brand-400"
        target="_blank"
        rel="noopener">Astro</a
      > 强力驱动.
    </p>
    <div class="flex items-center gap-4">
      {
        SOCIAL_LINKS.map((link) => (
          <a
            href={link.href}
            class="text-sm text-slate-500 transition hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400"
            target="_blank"
            rel="noopener"
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
