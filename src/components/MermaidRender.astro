---
// Mermaid 流程图渲染组件（按需加载）
// 用法：在文章 Markdown 中用 ```mermaid 代码块编写图表，本组件会在检测到 mermaid 块时才动态加载 mermaid 包
---

<script>
  function hasMermaid() {
    return document.querySelectorAll('pre[data-language="mermaid"]').length > 0;
  }

  async function loadAndRender() {
    if (!hasMermaid()) return;

    // 仅在确有 mermaid 代码块时才加载体积较大的 mermaid 包
    const mermaid = (await import('mermaid')).default;
    const isDark = document.documentElement.classList.contains('dark');
    mermaid.initialize({ startOnLoad: false, theme: isDark ? 'dark' : 'neutral' });

    let seq = 0;
    const blocks = document.querySelectorAll('pre[data-language="mermaid"]');
    blocks.forEach(async (pre) => {
      // 保存原始源码，供主题切换时重新渲染
      const code = pre.getAttribute('data-mermaid-src') || pre.textContent || '';
      pre.setAttribute('data-mermaid-src', code);
      pre.setAttribute('hidden', '');

      // 复用已创建的容器，避免重复插入
      let container = pre.nextElementSibling;
      if (!container || !container.classList.contains('mermaid-container')) {
        container = document.createElement('div');
        container.className =
          'mermaid-container my-8 flex justify-center rounded-xl border border-gray-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-900';
        pre.insertAdjacentElement('afterend', container);
      }

      try {
        const { svg } = await mermaid.render(`mermaid-${seq++}`, code);
        container.innerHTML = svg;
        container.classList.remove('border-red-300', 'dark:border-red-700');
      } catch {
        // mermaid 语法错误：保留原始代码
        container.textContent = code;
        container.classList.add('border-red-300', 'dark:border-red-700');
      }
    });
  }

  loadAndRender();

  // 监听主题切换，按当前主题重新渲染流程图（仅当存在 mermaid 块时）
  const observer = new MutationObserver(() => {
    if (hasMermaid()) loadAndRender();
  });
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class'],
  });
</script>
