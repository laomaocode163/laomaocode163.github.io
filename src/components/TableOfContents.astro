---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
// 仅取 h2 / h3 作为目录层级
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  toc.length > 0 && (
    <nav class="toc rounded-2xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-900">
      <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500">
        目录
      </p>
      <ul class="space-y-1.5 text-sm">
        {toc.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              class:list={[
                'block text-slate-600 transition hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400',
                h.depth === 3 ? 'pl-4' : '',
              ]}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
