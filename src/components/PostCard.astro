---
import type { CollectionEntry } from 'astro:content';
import TagPill from './TagPill.astro';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;

const dateStr = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const isoDate = pubDate.toISOString();
---

<a
  href={`/posts/${post.id}/`}
  class="group flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-6 transition duration-200 hover:-translate-y-1 hover:border-brand-300 hover:shadow-lg hover:shadow-brand-500/5 dark:border-slate-800 dark:bg-slate-900 dark:hover:border-brand-700"
>
  <time datetime={isoDate} class="text-xs text-slate-400 dark:text-slate-500">
    {dateStr}
  </time>

  <h3
    class="mt-3 text-lg font-semibold text-slate-900 transition-colors group-hover:text-brand-600 dark:text-slate-100 dark:group-hover:text-brand-400"
  >
    {title}
  </h3>

  <p
    class="mt-2 line-clamp-3 flex-1 text-sm leading-6 text-slate-600 dark:text-slate-400"
  >
    {description}
  </p>

  {
    tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <TagPill tag={tag} />
        ))}
      </div>
    )
  }
</a>
